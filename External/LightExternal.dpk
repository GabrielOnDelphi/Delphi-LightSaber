package LightExternal;

{$R *.res}
{$IFDEF IMPLICITBUILDING This IFDEF should not be used by users}
{$ALIGN 2}
{$ASSERTIONS OFF}
{$BOOLEVAL OFF}
{$DEBUGINFO OFF}
{$EXTENDEDSYNTAX ON}
{$IMPORTEDDATA ON}
{$IOCHECKS ON}
{$LOCALSYMBOLS ON}
{$LONGSTRINGS ON}
{$OPENSTRINGS ON}
{$OPTIMIZATION ON}
{$OVERFLOWCHECKS OFF}
{$RANGECHECKS OFF}
{$REFERENCEINFO ON}
{$SAFEDIVIDE OFF}
{$STACKFRAMES ON}
{$TYPEDADDRESS OFF}
{$VARSTRINGCHECKS ON}
{$WRITEABLECONST OFF}
{$MINENUMSIZE 1}
{$IMAGEBASE $400000}
{$DEFINE RELEASE}
{$ENDIF IMPLICITBUILDING}
{$DESCRIPTION 'LightSaber - Expernal code'}
{$LIBSUFFIX AUTO}
{$IMPLICITBUILD OFF}

requires
  rtl,
  vcl;

contains
  DirectoryWatch in 'DirectoryWatch.pas',
  DiskDrives in 'DiskDrives.pas',
  AniImg in 'AniImg.pas',
  VclUtilsExt in 'VclUtilsExt.pas',
  FastJpegDec in 'FastJpegDec.pas',
  FastJpegDecHelper in 'FastJpegDecHelper.pas',
  GifProperties in 'GifProperties.pas',
  MonitorHelper in 'MonitorHelper.pas',
  HtmlParserEx in 'HtmlParserEx.pas',
  janFX in 'janFX.pas',
  janFxStretch in 'janFxStretch.pas';

end.

